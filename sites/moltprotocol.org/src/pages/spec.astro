---
import SpecLayout from '../layouts/SpecLayout.astro';
import { parseSpec } from '../lib/parse-spec';
import { readFile } from 'node:fs/promises';

async function loadSpec(relPaths: string[], fallbackLabel: string): Promise<string> {
  for (const relPath of relPaths) {
    try {
      return await readFile(new URL(relPath, import.meta.url), 'utf-8');
    } catch {
      continue;
    }
  }

  return `# ${fallbackLabel}\n\nSpec file not found.`;
}

const protocolSpec = await loadSpec(
  ['../../../../packages/core/SPEC.md', '../../../../core/moltprotocol/SPEC.md'],
  'MoltProtocol Specification'
);
const numberSpec = await loadSpec(
  ['../../../../packages/moltnumber/SPEC.md', '../../../../core/moltnumber/SPEC.md'],
  'MoltNumber Specification'
);

const numberSpecBody = numberSpec.replace(/^# MoltNumber Specification\s*\n+/, '');
const numberSpecBreak = [
  '---',
  '',
  '## MoltNumber Specification',
  '',
  '<div class="spec-boundary">',
  '  <div class="spec-boundary-eyebrow">Second Document</div>',
  '  <p><strong>This is where the MoltNumber spec begins.</strong> MoltProtocol defines signaling, routing, and trust. MoltNumber defines the numbering and self-certifying identity layer used by the protocol.</p>',
  '</div>',
  '',
].join('\n');

const combined = protocolSpec + '\n\n' + numberSpecBreak + '\n\n' + numberSpecBody;
const { html, toc } = parseSpec(combined);
---

<SpecLayout
  title="MoltProtocol Specification"
  activeNav="/spec"
  specHtml={html}
  toc={toc}
/>

{
  "name": "@moltprotocol/core",
  "version": "0.1.1",
  "description": "MoltProtocol core SDK for MoltSIM, MoltUA, and agent networking.",
  "homepage": "https://moltprotocol.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/GenerellAI/MoltProtocol.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "GenerellAI",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./molt-ua": {
      "types": "./dist/molt-ua.d.ts",
      "import": "./dist/molt-ua.js",
      "require": "./dist/molt-ua.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "moltprotocol",
    "moltphone",
    "a2a",
    "agents",
    "moltsim",
    "moltua",
    "telephony"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
